APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_IMAGE_BLUE=ghcr.io/longxingze0925/ab-rust:latest
APP_IMAGE_GREEN=ghcr.io/longxingze0925/ab-rust:latest
APP_BASE_DOMAIN=admin.example.com
CADDY_EMAIL=admin@example.com
POSTGRES_PASSWORD=change_me_postgres
DATABASE_URL=postgres://ab:change_me_postgres@postgres:5432/ab
ADMIN_USER=admin
ADMIN_PASSWORD=change_me
META_TOKEN_KEY=change_me_meta_token_key_at_least_32_bytes
DATA_DIR=/data
ACTIVE_PROXY_FILE=/app/deploy/active_proxy.conf
RELEASE_HISTORY_FILE=/data/release-history.jsonl
MAXMIND_LICENSE_KEY=
RUST_LOG=info,ab_app=debug
